{
  "name": "translation-ai-cli",
  "description": "A command-line tool for translating text using LLMs.",
  "version": "0.0.0",
  "author": "IBM Skills Network",
  "bin": {
    "translation-ai-cli": "./bin/run.js"
  },
  "bugs": "https://github.com/ibm-skills-network/translation-ai-cli/issues",
  "dependencies": {
  },
  "devDependencies": {
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "./bin",
    "./dist",
    "./oclif.manifest.json"
  ],
  "homepage": "https://github.com/ibm-skills-network/translation-ai-cli",
  "keywords": [
    "oclif"
  ],
  "license": "Apache 2.0",
  "main": "dist/index.js",
  "type": "module",
  "oclif": {
    "bin": "translation-ai-cli",
    "dirname": "translation-ai-cli",
    "commands": "./dist/commands",
    "plugins": [
    ],
    "topics": {
      "profiles": {
        "description": "Manage LLM provider profiles"
      },
      "translate": {
        "description": "Translate content between languages"
      }
    }
  },
  "repository": "ibm-skills-network/translation-ai-cli",
  "scripts": {
    "build": "shx rm -rf dist && tsc -b",
    "lint": "eslint",
    "postpack": "shx rm -f oclif.manifest.json",
    "posttest": "pnpm run lint",
    "prepack": "oclif manifest && oclif readme",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "version": "oclif readme && git add README.md"
  },
  "types": "dist/index.d.ts",
  "packageManager": "pnpm@10.34.4"
}
